```typescript
'use client'

import { useState } from 'react'
import { Droppable } from '@hello-pangea/dnd'
import { Plus } from 'lucide-react'
import { Column as ColumnType, Card as CardType } from '@/types'
import { useFlowStore } from '@/store/useFlowStore'
import CardComponent from './Card'

interface ColumnProps {
  column: ColumnType
  cards: CardType[]
  boardId: string
}

const COLUMN_HEADER_COLORS: Record<string, string> = {
  'A Fazer': 'bg-gray-500/20 text-gray-300',
  'Em Progresso': 'bg-blue-500/20 text-blue-300',
  'Em Revisão': 'bg-yellow-500/20 text-yellow-300',
  'Concluído': 'bg-green-500/20 text-green-300',
}

export default function Column({ column, cards, boardId }: ColumnProps) {
  const { addCard } = useFlowStore()
  const [isAddingCard, setIsAddingCard] = useState(false)
  const [newCardTitle, setNewCardTitle] = useState('')

  const headerColor = COLUMN_HEADER_COLORS[column.title] ?? 'bg-gray-500/20 text-gray-300'

  const handleAddCard = () => {
    if (!newCardTitle.trim()) return
    addCard(column.id, boardId, newCardTitle.trim())
    setNewCardTitle('')
    setIsAddingCard(false)
  }

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter') handleAddCard()
    if (e.key === 'Escape') {
      setIsAddingCard(false)
      setNewCardTitle('')
    }
  }

  return (
    <div className="flex flex-col w-72 min-w-[288px] bg-gray-900/50 rounded-2xl border border-gray-800">
      {/* Column header */}
      <div className="flex items-center justify-between px-4 py-3">
        <div className="flex items-center gap-2">
          <h2 className="text-sm font-semibold text-gray-200">{column.title}</h2>
          <span className={`inline-flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold ${headerColor}`}>
            {cards.length}
          </span>
        </div>
        <button
          onClick={() => setIsAddingCard(true)}
          className="w-6 h-6 rounded flex items-center justify-center text-gray-400 hover:text-white hover:bg-gray-700 transition-colors"
          title="Adicionar card"
        >
          <Plus size={14} />
        </button>
      </div>

      {/* Cards */}
      <Droppable droppableId={column.id}>
        {(provided, snapshot) => (
          <div
            ref={provided.innerRef}
            {...provided.droppableProps}
            className={`flex-1 min-h-[80px] px-3 pb-3 space-y-2 transition-colors ${
              snapshot.isDraggingOver ? 'bg-indigo-500/5 rounded-b-2xl' : ''
            }`}
          >
            {cards.map((card, index) => (
              <CardComponent key={card.id} card={card} index={index} />
            ))}
            {provided.placeholder}
          </div>
        )}
      </Droppable>

      {/* Add card input */}
      {isAddingCard ? (
        <div className="px-3 pb-3">
          <input
            autoFocus
            type="text"
            placeholder="Título do card..."
            value={newCardTitle}
            onChange={(e) => setNewCardTitle(e.target.value)}
            onKeyDown={handleKeyDown}
            onBlur={() => {
              if (!newCardTitle.trim()) {
                setIsAddingCard(false)
              }
            }}
            className="w-full px-3 py-2 bg-gray-800 border border-indigo-500/50 rounded-lg text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
          />
          <div className="flex gap-2 mt-2">
            <button
              onClick={handleAddCard}
              className="px-3 py-1.5 bg-indigo-500 hover:bg-indigo-600 text-white text-xs font-medium rounded-lg transition-colors"
            >
              Adicionar
            </button>
            <button
              onClick={() => { setIsAddingCard(false); setNewCardTitle('') }}
              className="px-3 py-1.5 text-gray-400 hover:text-white text-xs rounded-lg hover:bg-gray-700 transition-colors"
            >
              Cancelar
            </button>
          </div>
        </div>
      ) : (
        <button
          onClick={() => setIsAddingCard(true)}
          className="mx-3 mb-3 py-2 rounded-lg border border-dashed border-gray-700 text-gray-500 hover:text-gray-300 hover:border-gray-500 text-xs flex items-center justify-center gap-1 transition-colors"
        >
          <Plus size={12} />
          Adicionar card
        </button>
      )}
    </div>
  )
}
