              >
                <Trash2 size={16} />
                {confirmDelete ? 'Confirmar exclusão' : 'Excluir card'}
              </button>
              {confirmDelete && (
                <button
                  onClick={() => setConfirmDelete(false)}
                  className="ml-2 text-sm text-gray-400 hover:text-white transition-colors"
                >
                  Cancelar
                </button>
              )}
            </div>
          </div>
        </motion.div>
      </motion.div>
    </AnimatePresence>
  )
}
