@import "tailwindcss";
@plugin "tailwindcss-animate";

@custom-variant dark (&:where(.dark, .dark *));

@layer base {
  :root {
    --background: oklch(0.984 0.003 247.858);
    --foreground: oklch(0.141 0.005 285.823);
    --card: oklch(1 0 0);
    --card-foreground: oklch(0.141 0.005 285.823);
    --popover: oklch(1 0 0);
    --popover-foreground: oklch(0.141 0.005 285.823);
    --primary: oklch(0.546 0.245 264.376);
    --primary-foreground: oklch(0.984 0.003 247.858);
    --secondary: oklch(0.961 0.003 247.858);
    --secondary-foreground: oklch(0.141 0.005 285.823);
    --muted: oklch(0.961 0.003 247.858);
    --muted-foreground: oklch(0.522 0.016 285.938);
    --accent: oklch(0.961 0.003 247.858);
    --accent-foreground: oklch(0.141 0.005 285.823);
    --destructive: oklch(0.577 0.245 27.325);
    --destructive-foreground: oklch(0.984 0.003 247.858);
    --border: oklch(0.882 0.006 285.823);
    --input: oklch(0.882 0.006 285.823);
    --ring: oklch(0.546 0.245 264.376);
    --radius: 0.5rem;
  }

  .dark {
    --background: oklch(0.065 0.002 285.823);
    --foreground: oklch(0.984 0.003 247.858);
    --card: oklch(0.141 0.005 285.823);
    --card-foreground: oklch(0.984 0.003 247.858);
    --popover: oklch(0.141 0.005 285.823);
    --popover-foreground: oklch(0.984 0.003 247.858);
    --primary: oklch(0.546 0.245 264.376);
    --primary-foreground: oklch(0.984 0.003 247.858);
    --secondary: oklch(0.21 0.006 285.885);
    --secondary-foreground: oklch(0.984 0.003 247.858);
    --muted: oklch(0.21 0.006 285.885);
    --muted-foreground: oklch(0.63 0.014 285.938);
    --accent: oklch(0.21 0.006 285.885);
    --accent-foreground: oklch(0.984 0.003 247.858);
    --destructive: oklch(0.577 0.245 27.325);
    --destructive-foreground: oklch(0.984 0.003 247.858);
    --border: oklch(0.21 0.006 285.885);
    --input: oklch(0.21 0.006 285.885);
    --ring: oklch(0.546 0.245 264.376);
  }
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  padding: 0;
  background-color: var(--background);
  color: var(--foreground);
}

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #9ca3af;
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: #6b7280;
}

.dark ::-webkit-scrollbar-thumb {
  background: #374151;
}

.dark ::-webkit-scrollbar-thumb:hover {
  background: #4b5563;
}
