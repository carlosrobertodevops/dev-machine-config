{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.claude/skills",
    "~/.agents/**/*.md",
    "~/.config/opencode/*.md",
    "~/.config/opencode/skills/*.md",
    "~/.config/opencode/rules/*.md",
    "{env:PWD}/task/.md",
    "{env:PWD}/docs/*.md",
    "{env:PWD}/.claude/*.md",
    "{env:PWD}/.claude/rules/*.md",
    "{env:PWD}/CLAUDE.md"
  ],
  "mcp": {
    "aws-api": {
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "AWS_REGION",
        "-e",
        "AWS_API_MCP_PROFILE_NAME",
        "-e",
        "AWS_ACCESS_KEY_ID",
        "-e",
        "AWS_SECRET_ACCESS_KEY",
        "-e",
        "AWS_SESSION_TOKEN",
        "mcp/aws-api-mcp-server"
      ],
      "enabled": true,
      "environment": {
        "AWS_ACCESS_KEY_ID": "{env:AWS_ACCESS_KEY_ID}",
        "AWS_API_MCP_PROFILE_NAME": "{env:AWS_API_MCP_PROFILE_NAME}",
        "AWS_REGION": "{env:AWS_REGION}",
        "AWS_SECRET_ACCESS_KEY": "{env:AWS_SECRET_ACCESS_KEY}",
        "AWS_SESSION_TOKEN": "{env:AWS_SESSION_TOKEN}"
      },
      "type": "local"
    },
    "context-mode": {
      "command": ["context-mode"],
      "type": "local"
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "docker": {
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true,
      "type": "local"
    },
    "figma-desktop": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "firecrawl-mcp": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:FIRECRAWL_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/{env:FIRECRAWL_API_KEY}/v2/mcp"
    },
    "playwright": {
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true,
      "type": "local"
    },
    "serena": {
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "."
      ],
      "enabled": true,
      "type": "local"
    },
    "supabase": {
      "command": [
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref={env:SUPABASE_PROJECT_REF}"
      ],
      "enabled": true,
      "environment": {
        "SUPABASE_ACCESS_TOKEN": "{env:SUPABASE_ACCESS_TOKEN}"
      },
      "type": "local"
    },
    "terraform": {
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "openai/gpt-5.3-codex",
  "permission": "allow",
  "plugin": [
    "context-mode",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://api.openai.com/v1"
      }
    }
  }
}
